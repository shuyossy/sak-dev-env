<?xml version="1.0"?>
<ruleset name="Project PMD Ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <description>
    PMD 7.x の標準カテゴリをそのまま参照するフル ruleset。
    独自定義・除外は原則置かない（標準準拠）。
  </description>

  <!--
    ========================================================================
    特定ルールを除外したい場合のカスタマイズ方法
    ========================================================================
    1) 対象ルールの <rule ref="..."/> を閉じタグ付きに展開する
    2) 内側に <exclude name="XXX"/> を列挙する
    3) コミットメッセージまたはコード内コメントで除外理由を残す

    例: Spring Boot の @SpringBootApplication クラスを UseUtilityClass の
       対象外にしたいとき（※通常は @SuppressWarnings で個別対応を推奨）:

       <rule ref="category/java/design.xml">
         <exclude name="UseUtilityClass"/>
       </rule>

    個別ソースでの抑制は以下のいずれかで行える:
      - @SuppressWarnings("PMD.<RuleName>") アノテーション
      - 行末コメント // NOPMD - <理由>
    ファイル横断の抑制が必要になったら本 ruleset を上記パターンで編集する。
    ========================================================================
  -->

  <rule ref="category/java/bestpractices.xml">
    <!--
      GuardLogStatement: SLF4J のパラメータ化ログ (`log.info("{}", arg)`) は
      フォーマット文字列の組み立てが LoggerImpl 内部で遅延評価されるため、
      多くの場合 if (log.isInfoEnabled()) ガードは不要。引数式に副作用や
      高コスト計算がある場合のみ guard が意味を持つが、本ボイラープレートが
      推奨するパラメータ化ロギングではほぼ常に false positive。
    -->
    <exclude name="GuardLogStatement"/>
  </rule>

  <rule ref="category/java/codestyle.xml">
    <!--
      AtLeastOneConstructor: Lombok の @NoArgsConstructor / @RequiredArgsConstructor
      が生成するコンストラクタは PMD のソース解析時には存在しないため false positive。
    -->
    <exclude name="AtLeastOneConstructor"/>
    <!--
      LocalVariableCouldBeFinal / MethodArgumentCouldBeFinal: ローカル変数や
      引数への final 強制は Java 慣習として強くは推奨されない（特に Lombok
      生成コンストラクタの引数で大量に出る）。読み手の負荷が増えるだけなので除外。
    -->
    <exclude name="LocalVariableCouldBeFinal"/>
    <exclude name="MethodArgumentCouldBeFinal"/>
    <!--
      OnlyOneReturn: 多階層ネストを避けるための early-return パターンと衝突する。
      可読性のためむしろ early-return を推奨することが多い。
    -->
    <exclude name="OnlyOneReturn"/>
  </rule>

  <rule ref="category/java/codestyle.xml/ShortVariable">
    <properties>
      <!--
        `id`, `ex`, `e`, `a`, `t`, `i` などラムダや catch 内の慣用的に短い識別子を許容。
        既定 3 文字未満で警告 → 1 文字未満（実質無効）に緩和。
      -->
      <property name="minimum" value="1"/>
    </properties>
  </rule>

  <rule ref="category/java/codestyle.xml/ShortClassName">
    <properties>
      <!--
        `Trip`, `User`, `Item` 等の業務ドメインで自然な 4 文字名を許容（既定 5 -> 4）。
      -->
      <property name="minimum" value="4"/>
    </properties>
  </rule>

  <rule ref="category/java/codestyle.xml/LongVariable">
    <properties>
      <!--
        Spring の慣習的な変数名（`activityRepository`, `restTemplateBuilder` 等）は
        18-25 文字程度になりがち。既定 17 -> 30 に緩和。
      -->
      <property name="minimum" value="30"/>
    </properties>
  </rule>

  <rule ref="category/java/design.xml">
    <!--
      UseUtilityClass: Spring Boot の @SpringBootApplication が付与されたエントリ
      ポイントクラスは「main しかない」構造になりがちで、本ルールが構造的に常に
      false positive を出す。@SpringBootApplication は Spring が CGLIB プロキシ
      および @Configuration として扱うため private constructor 化や final 化は
      推奨されず、また本ボイラープレート方針として個別 @SuppressWarnings は禁止
      しているため、ルールセット側で除外する。
    -->
    <exclude name="UseUtilityClass"/>
    <!--
      LoosePackageCoupling: <packages> プロパティでプロジェクト固有のレイヤ構造を
      宣言しないと configerror になる仕様。ボイラープレート時点では具体的な
      レイヤ規約を強制しない方針で除外。適用先プロジェクトで必要なら復活させ、
      packages プロパティを設定して有効化する。
    -->
    <exclude name="LoosePackageCoupling"/>
  </rule>

  <rule ref="category/java/documentation.xml">
    <!--
      CommentRequired: 既定では public メソッドや field にも JavaDoc を要求するが、
      DTO / Form / record / Lombok 生成 getter/setter にとっては純粋な記述ノイズ。
      下記の property 緩和でクラスコメントだけを必須にする方針。
    -->
    <exclude name="CommentRequired"/>
  </rule>

  <rule ref="category/java/documentation.xml/CommentRequired">
    <properties>
      <!--
        クラスコメント (header) のみ Required を維持。
        フィールド・パブリックメソッド・enum などは Ignored にする。
        本ボイラープレートは「クラス単位の意図を JavaDoc で残し、内部の細部は
        命名と型で表現する」方針（PBI #2 のコード量最小化要件にも整合）。
      -->
      <property name="classCommentRequirement" value="required"/>
      <property name="fieldCommentRequirement" value="ignored"/>
      <property name="accessorCommentRequirement" value="ignored"/>
      <property name="publicMethodCommentRequirement" value="ignored"/>
      <property name="protectedMethodCommentRequirement" value="ignored"/>
      <property name="enumCommentRequirement" value="ignored"/>
    </properties>
  </rule>

  <rule ref="category/java/errorprone.xml">
    <!--
      AvoidCatchingGenericException: 外部システム連携（AI / HTTP / 外部 API）の
      境界では「あらゆる例外を捕捉してドメイン固有例外に包んで再 throw する」
      パターンが正しい。catch 対象が `Exception` / `RuntimeException` だと
      本ルールが構造的に flagging するため、ボイラープレートでは除外する。
      （swallow せず必ず再 throw する規律は code review で担保する方針。）
    -->
    <exclude name="AvoidCatchingGenericException"/>
  </rule>
  <rule ref="category/java/multithreading.xml"/>
  <rule ref="category/java/performance.xml"/>
  <rule ref="category/java/security.xml"/>

  <!--
    ========================================================================
    構造的に PMD 標準ルールと衝突する箇所の TOBE 化
    （rules/README.md §4.5 のフローに沿って判定。
     複数ファイルで構造的に再発するパターンは、個別 @SuppressWarnings ではなく
     ここで rule property を緩和する形で吸収する。）

    ※ PMD 7.x ではルール参照に <exclude-pattern> を置けないため、
       ファイル単位の exclude が必要なときは ruleset 全体への
       <exclude-pattern> か、rule の <properties> で許容範囲を広げる方法を取る。
    ========================================================================
  -->

  <!--
    AvoidDuplicateLiterals: テストデータでは同一文字列が頻出するのが自然
    （複数テストで同じ enum 名や定数を使う）。skipAnnotations を有効にし、
    アノテーションが付与されたフィールド／パラメータの重複文字列を許容する。
  -->
  <rule ref="category/java/errorprone.xml/AvoidDuplicateLiterals">
    <properties>
      <property name="skipAnnotations" value="true"/>
    </properties>
  </rule>

  <!--
    MethodNamingConventions: テストメソッド名はドメイン語彙や日本語、
    アンダースコア区切りで「自然言語に近い読みやすさ」を優先することが多い。
    junit テストパターンを緩和して許容する（本番コードのメソッド名は規約どおり）。
  -->
  <rule ref="category/java/codestyle.xml/MethodNamingConventions">
    <properties>
      <property name="junit5TestPattern" value="[a-zA-Z_぀-ゟ゠-ヿ一-鿿][a-zA-Z0-9_぀-ゟ゠-ヿ一-鿿]*"/>
      <property name="junit4TestPattern" value="[a-zA-Z_぀-ゟ゠-ヿ一-鿿][a-zA-Z0-9_぀-ゟ゠-ヿ一-鿿]*"/>
      <property name="junit3TestPattern" value="[a-zA-Z_぀-ゟ゠-ヿ一-鿿][a-zA-Z0-9_぀-ゟ゠-ヿ一-鿿]*"/>
    </properties>
  </rule>

  <!--
    TooManyMethods: テストクラスは振る舞いごとに 1 メソッド書くため
    既定の 10 メソッドではすぐに頭打ちになる。30 程度に緩和する。
    本番コードでも 30 を超えるなら設計の見直しを促せる、ちょうどよい上限。
  -->
  <rule ref="category/java/design.xml/TooManyMethods">
    <properties>
      <property name="maxmethods" value="30"/>
    </properties>
  </rule>
</ruleset>
